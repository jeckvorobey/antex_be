# Application
APP_ENV=dev
APP_HOST=localhost
APP_PORT=8000
APP_NAME=AntEx

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=http://localhost:9000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS="*"
CORS_ALLOW_HEADERS="*"

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/antex

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=86400
ADMIN_ACCESS_TTL_SECONDS=900
ADMIN_REFRESH_TTL_SECONDS=604800

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_USERNAME=antex_bot
ADMIN_ID=123456789
TELEGRAM_INIT_DATA_TTL_SECONDS=86400

# Telegram mode: polling (dev) / webhook (prod)
TELEGRAM_MODE=polling

# Webhook (only for TELEGRAM_MODE=webhook)
TELEGRAM_WEBHOOK_HOST=https://your-domain.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your-random-secret-token-here

# Frontend Mini App URL
FRONTEND_WEBAPP_URL=https://your-miniapp.com

# Operator chat ID
OPERATOR_CHAT_ID=123456789

# Exchange rates
# Коэффициент понижения для расчёта курса THB/RUB
REDUCING_FACTOR=0.6
# Наценка оператора (allowance) по умолчанию
DEFAULT_ALLOWANCE=0.02
# TTL кэша курсов в секундах
RATE_CACHE_TTL_SECONDS=1800

# CoinGecko API
COINGECKO_API_KEY=your-coingecko-api-key

# Review channel
REVIEW_CHANNEL_ID=-1001234567890

# Timezone
TIMEZONE=Asia/Bangkok

# i18n
APP_LOCALE_DEFAULT=ru
APP_LOCALE_SUPPORTED=ru,en
